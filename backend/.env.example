# ══════════════════════════════════════════════════════════════
# Casinozz Backend — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy to .env and fill in your values. NEVER commit .env to git!

# ── Database (Neon PostgreSQL) ───────────────────────────────
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# ── ML SERVICE ──────────────────────────────────────────────────────────────
# URL to your Python ML service (Render URL in production)
ML_SERVICE_URL=http://127.0.0.1:5001
# Request timeout in milliseconds
ML_SERVICE_TIMEOUT=8000
# Internal API key for Node→ML communication (must match in both services)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=CHANGE_ME_TO_A_RANDOM_STRING

# ── AUTH & SECURITY ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING

# ── EXTERNAL APIS ──────────────────────────────────────────────────────────
# Gemini API Key for AI Insights
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ── Runtime ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
