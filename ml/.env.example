# ══════════════════════════════════════════════════════════════
# Casinozz ML Service — Environment Variables
# ══════════════════════════════════════════════════════════════

# Database (only used during /train — the ML service is otherwise DB-free)
DATABASE_URL=mysql://user:password@host:port/casinozz_v2

# Internal API key (MUST match the backend's INTERNAL_API_KEY)
INTERNAL_API_KEY=CHANGE_ME_TO_SAME_KEY_AS_BACKEND

# CORS (restrict origins in production)
ALLOWED_ORIGINS=https://your-backend.up.railway.app

# Runtime
FLASK_ENV=production
